<?php
/**
 * CBPT (CCBill Charge By Previous Transaction) Shared Library
 * Extracted from the WORKING cbpt-charge.php
 * Used by: cbpt-charge.php (tips), ppv-unlock.php (PPV unlocks)
 */

require_once __DIR__ . '/../../.secrets.php';
require_once __DIR__ . '/config.php';

/**
 * Charge a fan's stored payment method via CCBill CBPT
 * 
 * @param int $fanUserId Fan's user ID
 * @param float $amount Amount in dollars
 * @param string $description Charge description
 * @param SQLite3 $db Database connection
 * @return array ['success' => bool, 'subscription_id' => string, 'amount' => float, 'card_last_four' => string, 'error' => string, 'decline_code' => string]
 */
function chargeCBPT($fanUserId, $amount, $description, $db) {
    try {
        if (!$fanUserId || $amount <= 0) {
            return ['success' => false, 'error' => 'Invalid fan_user_id or amount'];
        }
        if ($amount > 500) {
            return ['success' => false, 'error' => 'Amount cannot exceed $500'];
        }

        // 1. Look up stored payment method
        $stmt = $db->prepare("SELECT ccbill_subscription_id, card_last_four, card_type FROM fan_payment_methods WHERE fan_user_id = :uid");
        $stmt->bindValue(':uid', $fanUserId, SQLITE3_INTEGER);
        $result = $stmt->execute();
        $paymentMethod = $result->fetchArray(SQLITE3_ASSOC);

        if (!$paymentMethod || !$paymentMethod['ccbill_subscription_id']) {
            return ['success' => false, 'error' => 'No stored payment method found for this fan'];
        }

        $storedSubId = $paymentMethod['ccbill_subscription_id'];
        $cardLastFour = $paymentMethod['card_last_four'] ?? '';

        // 2. Use live CCBill credentials
        $clientAccnum = defined('CCBILL_ACCOUNT') ? CCBILL_ACCOUNT : '955253';
        $newClientAccnum = $clientAccnum;
        $newClientSubacc = defined('CCBILL_SUB_ONETIME') ? CCBILL_SUB_ONETIME : '0001';
        $username = defined('CCBILL_DATALINK_USER') ? CCBILL_DATALINK_USER : 'bryaDL12';
        $password = defined('CCBILL_DATALINK_PASS') ? CCBILL_DATALINK_PASS : 'uM@7tF@4';

        // 3. Build CBPT API request (GET to bill.ccbill.com)
        $apiParams = [
            'action' => 'chargeByPreviousTransactionId',
            'subscriptionId' => $storedSubId,
            'clientAccnum' => $clientAccnum,
            // NOTE: clientSubacc intentionally omitted — causes -10 when combined with newClientSubacc
            'username' => $username,
            'password' => $password,
            'newClientAccnum' => $newClientAccnum,
            'newClientSubacc' => $newClientSubacc,
            'sharedAuthentication' => '1',
            'currencyCode' => '840',
            'initialPrice' => number_format($amount, 2, '.', ''),
            'initialPeriod' => '3', // Must be 3 for one-time charges
            'recurringPrice' => '0.00',
            'recurringPeriod' => '0',
            'rebills' => '0',
            'returnXML' => '1'
        ];

        $apiUrl = 'https://bill.ccbill.com/jpost/billingApi.cgi?' . http_build_query($apiParams);

        $context = stream_context_create([
            'http' => [
                'method' => 'GET',
                'timeout' => 30,
                'user_agent' => 'Breyya CBPT Client/1.0'
            ]
        ]);

        error_log("CBPT Request: account=$clientAccnum user=$username subId=$storedSubId amount=$amount desc=$description");

        $response = @file_get_contents($apiUrl, false, $context);

        if ($response === false) {
            error_log("CBPT Error: Failed to connect to CCBill API");
            return ['success' => false, 'error' => 'Failed to connect to payment processor'];
        }

        error_log("CBPT Response: " . substr($response, 0, 500));

        // Check for -10 (access denied)
        if (trim($response) === '-10' || strpos($response, '>-10<') !== false) {
            error_log("CBPT Error: DataLink access denied (-10)");
            return ['success' => false, 'error' => 'Payment service temporarily unavailable', 'decline_code' => '-10'];
        }

        // 4. Parse response — CCBill returns XML, URL-encoded, or CSV
        $trimmedResponse = trim($response);
        $xml = @simplexml_load_string($response);

        if ($xml) {
            // XML format
            $approved = (string)($xml->approved ?? '0');
            $newSubscriptionId = (string)($xml->subscriptionId ?? '');
            $declineCode = (string)($xml->declineCode ?? '');
            $declineText = (string)($xml->declineText ?? '');
        } elseif (preg_match('/^(Success|Error):\s*(.+)$/s', $trimmedResponse, $matches)) {
            // URL-encoded format: "Success: key=val&key=val"
            parse_str(trim($matches[2]), $kvData);
            if ($matches[1] === 'Success') {
                $approved = '1';
                $newSubscriptionId = $kvData['subscriptionId'] ?? '';
                $declineCode = '';
                $declineText = '';
            } else {
                $approved = '0';
                $newSubscriptionId = '';
                $declineCode = $kvData['declineCode'] ?? $kvData['errorCode'] ?? 'unknown';
                $declineText = $kvData['declineText'] ?? $kvData['errorMessage'] ?? 'Payment declined';
            }
        } else {
            // CSV fallback
            $lines = explode("\n", $trimmedResponse);
            if (count($lines) >= 2) {
                $fields = str_getcsv($lines[0]);
                $values = str_getcsv($lines[1]);
                if (count($fields) === count($values)) {
                    $csvData = array_combine($fields, $values);
                } else {
                    $csvData = [];
                }
                $approved = $csvData['approved'] ?? '0';
                $newSubscriptionId = $csvData['subscriptionId'] ?? '';
                $declineCode = $csvData['declineCode'] ?? '';
                $declineText = $csvData['declineText'] ?? '';
            } else {
                error_log("CBPT Error: Unparseable response: $response");
                return ['success' => false, 'error' => 'Payment processor returned invalid response'];
            }
        }

        // 5. Process result
        if ($approved === '1') {
            $amountCents = intval($amount * 100);

            // Record transaction
            $db->exec("CREATE TABLE IF NOT EXISTS transactions (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                user_id INTEGER NOT NULL,
                type TEXT NOT NULL,
                amount_cents INTEGER NOT NULL,
                description TEXT,
                reference_id TEXT,
                status TEXT DEFAULT 'completed',
                created_at DATETIME DEFAULT CURRENT_TIMESTAMP
            )");

            $stmt = $db->prepare("INSERT INTO transactions (user_id, type, amount_cents, description, reference_id, status) VALUES (:uid, 'charge', :amount, :desc, :ref, 'completed')");
            $stmt->bindValue(':uid', $fanUserId, SQLITE3_INTEGER);
            $stmt->bindValue(':amount', $amountCents, SQLITE3_INTEGER);
            $stmt->bindValue(':desc', $description, SQLITE3_TEXT);
            $stmt->bindValue(':ref', $newSubscriptionId, SQLITE3_TEXT);
            $stmt->execute();

            error_log("CBPT Success: Fan $fanUserId charged $" . number_format($amount, 2) . " - $description - newSubId: $newSubscriptionId");

            return [
                'success' => true,
                'subscription_id' => $newSubscriptionId,
                'amount' => $amount,
                'description' => $description,
                'card_last_four' => $cardLastFour
            ];
        } else {
            $errorMsg = $declineText ?: "Payment declined (Code: $declineCode)";
            error_log("CBPT Declined: Fan $fanUserId - $errorMsg (code: $declineCode)");

            return [
                'success' => false,
                'error' => $errorMsg,
                'decline_code' => $declineCode
            ];
        }

    } catch (\Throwable $e) {
        error_log("CBPT Exception: " . $e->getMessage() . " at " . $e->getFile() . ":" . $e->getLine());
        return ['success' => false, 'error' => 'Payment processing failed: ' . $e->getMessage()];
    }
}
